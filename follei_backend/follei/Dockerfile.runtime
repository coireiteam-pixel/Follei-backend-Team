FROM python:3.12-slim

WORKDIR /usr/src/app

RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    "sqlalchemy>=2.0.0" \
    psycopg2-binary \
    pydantic-settings \
    email-validator \
    alembic \
    anthropic

COPY . .

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
